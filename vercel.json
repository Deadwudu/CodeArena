{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix ClientApp",
  "buildCommand": "npm run build --prefix ClientApp",
  "outputDirectory": "ClientApp/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
